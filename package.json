{
  "name": "bav-livery-manager",
  "version": "1.0.1",
  "description": "Livery manager for BAV",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"bun run dev:renderer\" \"bun run dev:ts\" \"bun run dev:electron\"",
    "dev:renderer": "vite dev --host",
    "dev:ts": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/electron/main.js && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "bun run build:renderer && bun run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.electron.json",
    "build:exe": "bun run build && electron-builder --win --x64 --publish never",
    "build:exe:publish": "bun run build && electron-builder --win --x64 --publish always",
    "start": "bun run build && electron .",
    "electron": "electron .",
    "generate-icons": "node scripts/generate-icons.js"
  },
  "author": "Pavel Sergienko, Laurie Cooper",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/p-sergienko/bav-livery-manager.git"
  },
  "packageManager": "bun@1.2.21",
  "dependencies": {
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@tanstack/react-query": "^5.100.14",
    "archiver": "^6.0.2",
    "electron-devtools-installer": "^4.0.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-fade": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.3.5",
    "msfs-layout-generator": "^0.3.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.7",
    "react-feather": "^2.0.10",
    "react-loading-skeleton": "^3.5.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "shepherd.js": "^15.2.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/archiver": "^5.3.4",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.0",
    "cross-env": "^10.1.0",
    "electron": "42.3.3",
    "electron-builder": "^26.15.2",
    "icon-gen": "^5.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "build": {
    "productName": "BAVirtual Livery Manager",
    "asar": true,
    "compression": "maximum",
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": [
          "BAV-Livery-Manager.png",
          "BAV-Livery-Manager.ico"
        ]
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "localVersion.json",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "BAV-Livery-Manager-${version}-Setup.${ext}",
      "compression": "maximum",
      "icon": "public/BAV-Livery-Manager.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "p-sergienko",
      "repo": "bav-livery-manager",
      "releaseType": "release"
    }
  }
}
