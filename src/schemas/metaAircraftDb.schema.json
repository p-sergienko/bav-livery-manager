{
  "openapi": "3.1.0",
  "info": {
    "title": "BAVirtual Meta Aircraft Database API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/v2/meta/aircraft-db": {
      "get": {
        "summary": "Get aircraft database",
        "description": "Returns the full aircraft registration database.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Full list of aircraft records",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AircraftRecordArray"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorised"
          },
          "403": {
            "description": "Forbidden — admin role required"
          }
        }
      },
      "put": {
        "summary": "Save aircraft database",
        "description": "Replaces the full aircraft registration database with the provided records.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AircraftRecordArray"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Database saved successfully"
          },
          "400": {
            "description": "Invalid request body"
          },
          "401": {
            "description": "Unauthorised"
          },
          "403": {
            "description": "Forbidden — admin role required"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "AircraftRecord": {
        "type": "object",
        "description": "A single aircraft registration entry",
        "required": [
          "registration",
          "aircraftType",
          "engine",
          "category",
          "year",
          "livery"
        ],
        "additionalProperties": false,
        "properties": {
          "registration": {
            "type": "string",
            "description": "Aircraft registration (e.g. G-EUUA)",
            "pattern": "^[A-Z0-9\\-]+$"
          },
          "aircraftType": {
            "type": "string",
            "description": "Aircraft type code (e.g. A320, B77W, E190)"
          },
          "engine": {
            "type": "string",
            "description": "Engine variant (e.g. IAE, GE90)"
          },
          "category": {
            "type": "string",
            "description": "Aircraft subsidiary",
            "enum": [
              "Mainline",
              "Euroflyer",
              "Cityflyer"
            ]
          },
          "year": {
            "type": "string",
            "description": "Year the aircraft entered service",
            "pattern": "^[0-9]{4}$"
          },
          "livery": {
            "type": "string",
            "description": "Livery name"
          }
        }
      },
      "AircraftRecordArray": {
        "type": "array",
        "description": "Ordered list of aircraft registration records",
        "items": {
          "$ref": "#/components/schemas/AircraftRecord"
        }
      }
    }
  }
}